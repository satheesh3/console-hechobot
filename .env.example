# --- App ---
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# --- Postgres ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=whatsapp_reseller
DB_LOGGING=false

# --- Admin auth (JWT for admin/back-office users) ---
ADMIN_JWT_SECRET=replace-me-with-a-long-random-string
ADMIN_JWT_EXPIRES_IN=12h

# --- YCloud BSP credentials (TODO: replace stubs with real values) ---
# Master/partner API key used to provision channels on behalf of clients.
YCLOUD_API_KEY=replace-me-ycloud-api-key
YCLOUD_BASE_URL=https://api.ycloud.com/v2
# Shared secret YCloud uses to sign inbound webhooks (HMAC-SHA256).
YCLOUD_WEBHOOK_SECRET=replace-me-webhook-secret

# --- Outbound webhook fan-out ---
WEBHOOK_DELIVERY_MAX_ATTEMPTS=8
WEBHOOK_DELIVERY_TIMEOUT_MS=10000
